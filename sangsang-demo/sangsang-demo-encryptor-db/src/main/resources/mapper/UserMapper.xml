<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sangsang.demo.mapper.UserMapper">
    <select id="getUserListByPhone"
            resultType="com.sangsang.demo.vo.UserVo">
        select *
        from demo_user
        where phone = #{phone}
    </select>
    <select id="findAll"
            resultType="com.sangsang.demo.vo.UserVo">
        select *
        from demo_user
    </select>
</mapper>

